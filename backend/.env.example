# EchoBridge AI — environment variables
# Copy to .env and fill in real values before deploying.
# Never commit .env to version control.

# ── Core ──────────────────────────────────────────────────────────────────────
ENVIRONMENT=development
PORT=8000
DEBUG=true
BACKEND_URL=http://localhost:8000
CORS_ORIGINS=["http://localhost:3000","http://localhost:3002"]

# ── Backboard (AI backbone) ───────────────────────────────────────────────────
BACKBOARD_API_KEY=
BACKBOARD_BASE_URL=https://app.backboard.io/api

# ── ElevenLabs (TTS / sponsor) ────────────────────────────────────────────────
ELEVENLABS_API_KEY=
ELEVENLABS_VOICE_ID=21m00Tcm4TlvDq8ikWAM

# ── Google Cloud (STT / sponsor) ──────────────────────────────────────────────
GOOGLE_CLOUD_PROJECT_ID=
GOOGLE_APPLICATION_CREDENTIALS=/opt/echobridge/gcp-credentials.json

# ── Cloudinary (media storage / sponsor) ─────────────────────────────────────
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# ── Supabase (database / sponsor) ─────────────────────────────────────────────
SUPABASE_URL=
SUPABASE_KEY=

# ── Tailscale (private networking) ────────────────────────────────────────────
TAILSCALE_ENABLED=false
TAILSCALE_HOSTNAME=

# ── Auth0 (authentication) ────────────────────────────────────────────────────
AUTH0_DOMAIN=
AUTH0_AUDIENCE=

ELEVENLABS_MODEL_ID=eleven_multilingual_v2
